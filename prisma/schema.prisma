generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id            String              @id @default(cuid())
  name          String
  email         String              @unique
  passwordHash  String
  projects      Project[]
  risks         Risk[]
  memberships   WorkspaceMember[]
  integrations  Integration[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model Integration {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider  String
  token     String
  settings  String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}

model Workspace {
  id        String              @id @default(cuid())
  name      String
  slug      String              @unique
  members   WorkspaceMember[]
  projects  Project[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        String    @default("member") // owner, admin, member
  createdAt   DateTime  @default(now())

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
}

model Project {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId   String?
  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  code          String
  name          String
  client        String
  stage         String     @default("Planning")
  phase         Int        @default(1)
  health        Int        @default(100)
  risk          String     @default("Low")
  next          String     @default("")
  nextWhen      String     @default("")
  budget        String     @default("On track")
  budgetState   String     @default("good")
  schedule      String     @default("On track")
  scheduleState String     @default("good")
  lastTouch     DateTime   @default(now())
  owner         String     @default("")
  contact       String     @default("")
  channel       String     @default("Email")
  move          String     @default("")
  moveBody      String     @default("")
  checkinDays   Int        @default(7)
  estimatedHours Float?
  estimatedCost  Float?
  risks         Risk[]
  tasks         Task[]
  timeEntries   TimeEntry[]
  financials    FinancialEntry[]
  shares        ProjectShare[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([userId])
  @@index([workspaceId])
}

model ProjectShare {
  id           String          @id @default(cuid())
  token        String          @unique @default(cuid())
  projectId    String
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  passwordHash String
  createdBy    String
  active       Boolean         @default(true)
  messages     ClientMessage[]
  createdAt    DateTime        @default(now())

  @@index([projectId])
}

model ClientMessage {
  id        String       @id @default(cuid())
  shareId   String
  share     ProjectShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
  from      String
  message   String
  createdAt DateTime     @default(now())

  @@index([shareId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  action    String   // create, update, delete, risk_add, risk_resolve, share
  detail    String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([projectId])
}

model SavedView {
  id        String   @id @default(cuid())
  userId    String
  name      String
  layout    String   // JSON string of LayoutItem[]
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Task {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  assignee    String    @default("")
  status      String    @default("todo") // todo, in_progress, blocked, done
  priority    String    @default("medium") // low, medium, high
  dueDate     DateTime?
  completedAt DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
}

model TimeEntry {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  hours     Float
  date      DateTime @default(now())
  note      String   @default("")
  taskId    String?
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([userId])
}

model FinancialEntry {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String   // cost, po, invoice, payment
  amount    Float
  description String @default("")
  reference String   @default("") // PO number, invoice number
  date      DateTime @default(now())
  status    String   @default("pending") // pending, approved, paid
  createdAt DateTime @default(now())

  @@index([projectId])
}

model Risk {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  owner     String   @default("")
  severity  String   @default("med")
  impact    String   @default("")
  action    String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([projectId])
}
